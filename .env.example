# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
JWT_SECRET=your_jwt_secret_here

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=bethapi

# Redis & Asynq
REDIS_ADDR=localhost:6379

# Resend (Emails)
RESEND_API_KEY=re_123456789

# Google AI Studio
GOOGLE_AI_API_KEY=your_google_ai_studio_api_key

# Cloudflare R2
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_ENDPOINT=https://accountid.r2.cloudflarestorage.com
R2_BUCKET=bethapi-videos
R2_PUBLIC_DOMAIN=https://pub-yourdomain.r2.dev

# Pricing (Credits)
PRICING_LLMPROMPT1K=1.0
PRICING_LLMOUTPUT1K=2.0
PRICING_VIDEOSEC=10.0
PRICING_IMAGEN=50.0

# Subscriptions (Price IDs)
SUBSCRIPTION_PRO_PRICE_ID=price_pro_id
SUBSCRIPTION_ULTRA_PRICE_ID=price_ultra_id

# Renewal & Grace Period
RENEWAL_GRACE_PERIOD_HOURS=48
RENEWAL_NOTIFY_COUNT=4
